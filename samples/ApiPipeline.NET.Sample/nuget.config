<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="baps-apps-packages" value="https://nuget.pkg.github.com/baps-apps/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="baps-apps-packages">
      <package pattern="ApiPipeline.NET" />
      <package pattern="ApiPipeline.NET.OpenTelemetry" />
      <package pattern="CodeStyle.NET" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
